# Database Configuration
# Set this to a PostgreSQL connection string for production.
# In development, the app will fall back to SQLite if DATABASE_URL is not set.
DATABASE_URL=postgresql://postgres@127.0.0.1:5432/centre_tour_booking
SQLITE_FILE=artifacts/api-server/data/dev.sqlite

# API Server Configuration
PORT=8080
NODE_ENV=development
SESSION_SECRET=your_session_secret_here

# Frontend (Vite) Configuration
BASE_PATH=/

# WhatsApp Business Cloud API (Meta)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# Mailercloud Email API v2.0 Configuration
MAILERCLOUD_API_KEY=your_mailercloud_api_key
MAILERCLOUD_SENDER_EMAIL=sender@example.com
MAILERCLOUD_SENDER_NAME="FirstCry Intellitots"
